{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Test Taker",
  "version": "1.2.0",
  "identifier": "com.testtaker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Test Taker",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Professional test-taking desktop application",
    "longDescription": "Test Taker is a visual interface for JSON-based tests. Import tests, answer questions, and export response JSON — fully offline.",
    "category": "Education",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
